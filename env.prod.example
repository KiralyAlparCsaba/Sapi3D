# Production Environment Variables Template
# IMPORTANT: Never use development values in production!

# Database Configuration
DATABASE_URL=postgresql+asyncpg://sapi3d:CHANGE_THIS_PROD_DB_PASSWORD@db:5432/sapi3d
POSTGRES_USER=sapi3d
POSTGRES_PASSWORD=CHANGE_THIS_PROD_DB_PASSWORD
POSTGRES_DB=sapi3d

# JWT Configuration (MUST BE CHANGED FOR PRODUCTION)
# Generate a secure random string (min 32 characters):
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_THIS_JWT_SECRET_PROD_MIN_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Backend Configuration
API_TITLE=Sapi3D Backend API
API_VERSION=0.1.0
RELOAD=false
DEBUG=false

# CORS Configuration (restrictive for production)
# Update with your actual production domain
CORS_ORIGINS=["CHANGE_THIS_PRODUCTION_DOMAIN"]

# Frontend Configuration
# Update with your actual production API URL
VITE_API_URL=CHANGE_THIS_PRODUCTION_API_URL
VITE_ENV=production
