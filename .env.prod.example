# Production Environment Variables
# Used by docker-compose.prod.yml
# This file is copied to .env by run_prod.sh

# IMPORTANT: Replace all CHANGE_THIS placeholders before running in production!

# Database Configuration
DATABASE_URL=postgresql+asyncpg://sapi3d:CHANGE_THIS_PASSWORD@db:5432/sapi3d
POSTGRES_USER=sapi3d
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=sapi3d

# JWT Configuration (MUST BE CHANGED FOR PRODUCTION)
# Generate a secure random string (min 32 characters):
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE_THIS_TO_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Backend Configuration
API_TITLE=Sapi3D Backend API
API_VERSION=0.1.0
RELOAD=false
DEBUG=false

# CORS Configuration (restrictive for production)
# Update with your actual production domain
CORS_ORIGINS=["http://localhost:3000"]

# Frontend Configuration
# Update with your actual production API URL
VITE_API_URL=http://localhost:8000
VITE_ENV=production
