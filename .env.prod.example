# Production Environment Variables
# Copy this file to .env.prod and fill in with actual production values
# NEVER commit .env.prod to version control!

# Database Configuration
POSTGRES_USER=sapi3d
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
POSTGRES_DB=sapi3d

# Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO

# Security Settings
SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
JWT_SECRET_KEY=CHANGE_THIS_TO_ANOTHER_RANDOM_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings (adjust for your domain)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional: External Services
# SENTRY_DSN=your_sentry_dsn_here
# REDIS_URL=redis://redis:6379/0
