# Development Environment Variables
# Used by docker-compose.dev.yml
# This file is copied to .env by run_dev.sh

# Database Configuration
DATABASE_URL=postgresql+asyncpg://sapi3d:sapi3d_password@db:5432/sapi3d
POSTGRES_USER=sapi3d
POSTGRES_PASSWORD=sapi3d_password
POSTGRES_DB=sapi3d

# JWT Configuration (Development - NOT FOR PRODUCTION)
JWT_SECRET_KEY=supersecretkey123
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Backend Configuration
API_TITLE=Sapi3D Backend API (Development)
API_VERSION=0.1.0
RELOAD=true
DEBUG=true

# CORS Configuration (permissive for development)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_ENV=development
