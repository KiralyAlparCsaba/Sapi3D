# Development Environment Variables Template

# Database Configuration
DATABASE_URL=postgresql+asyncpg://sapi3d:CHANGE_THIS_DEV_DB_PASSWORD@db:5432/sapi3d
POSTGRES_USER=sapi3d
POSTGRES_PASSWORD=CHANGE_THIS_DEV_DB_PASSWORD
POSTGRES_DB=sapi3d

# JWT Configuration (Development)
# Generate a secure random string:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_THIS_JWT_SECRET_DEV_MIN_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Backend Configuration
API_TITLE=Sapi3D Backend API (Development)
API_VERSION=0.1.0
RELOAD=true
DEBUG=true

# CORS Configuration (permissive for development)
CORS_ORIGINS=["*"]

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_ENV=development
